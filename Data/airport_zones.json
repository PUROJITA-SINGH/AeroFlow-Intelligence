      "action": "Trigger alert"
    },
    {
      "rule_id": 3,
      "name": "Anomaly Detected",
      "condition": "isolation_forest_score == -1",
      "severity": "Critical",
      "action": "Trigger alert + log anomaly"
    },
    {
      "rule_id": 4,
      "name": "Auto Resolve",
      "condition": "passenger_count < capacity * 0.7 AND queue_length < 10",
      "severity": "Info",
      "action": "Auto-resolve existing alert"
    }
