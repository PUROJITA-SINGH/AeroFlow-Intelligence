  "alert_rules": [
    {
      "rule_id": 1,
      "name": "Capacity Exceeded",
      "condition": "passenger_count > capacity * 1.2",
      "severity": "Critical",
      "action": "Trigger alert + notify operations"
    },
    {
      "rule_id": 2,
      "name": "Queue Too Long",
